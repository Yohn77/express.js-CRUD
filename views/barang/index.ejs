<div class="row">
    <div class="col-md-12">
        <div class="card">
            <div class="card-header bg-white d-flex justify-content-between align-items-center">
                <h4 class="mb-0">
                    <i class="bi bi-boxes"></i> Daftar Barang
                </h4>
                <a href="/barang/create" class="btn btn-primary btn-sm">
                    <i class="bi bi-plus-circle"></i> Tambah Barang
                </a>
            </div>
            <div class="card-body">
                <!-- Search Form -->
                <form action="/barang/search" method="GET" class="mb-3">
                    <div class="input-group">
                        <input type="text" name="keyword" class="form-control" 
                               placeholder="Cari barang..." value="<%= keyword || '' %>">
                        <button class="btn btn-outline-secondary" type="submit">
                            <i class="bi bi-search"></i> Cari
                        </button>
                        <% if (keyword) { %>
                            <a href="/barang" class="btn btn-outline-danger">
                                <i class="bi bi-x-circle"></i> Reset
                            </a>
                        <% } %>
                    </div>
                </form>

                <% if (barang && barang.length > 0) { %>
                    <div class="table-responsive">
                        <table class="table table-hover table-striped">
                            <thead>
                                <tr>
                                    <th>ID</th>
                                    <th>Kode Barang</th>
                                    <th>Nama Barang</th>
                                    <th>Kategori</th>
                                    <th>Harga</th>
                                    <th>Stok</th>
                                    <th>Aksi</th>
                                </tr>
                            </thead>
                            <tbody>
                                <% barang.forEach(item => { %>
                                    <tr>
                                        <td><%= item.id %></td>
                                        <td><span class="badge bg-secondary"><%= item.kode_barang %></span></td>
                                        <td><strong><%= item.nama_barang %></strong></td>
                                        <td><span class="badge bg-info"><%= item.kategori || '-' %></span></td>
                                        <td>Rp <%= new Intl.NumberFormat('id-ID').format(item.harga) %></td>
                                        <td>
                                            <span class="badge <%= item.stok > 10 ? 'bg-success' : item.stok > 0 ? 'bg-warning' : 'bg-danger' %>">
                                                <%= item.stok %>
                                            </span>
                                        </td>
                                        <td>
                                            <a href="/barang/edit/<%= item.id %>" class="btn btn-warning btn-sm">
                                                <i class="bi bi-pencil"></i>
                                            </a>
                                            <a href="/barang/delete/<%= item.id %>" 
                                               class="btn btn-danger btn-sm"
                                               onclick="return confirm('Apakah Anda yakin ingin menghapus barang ini?')">
                                                <i class="bi bi-trash"></i>
                                            </a>
                                        </td>
                                    </tr>
                                <% }) %>
                            </tbody>
                        </table>
                    </div>
                    <div class="mt-3">
                        <small class="text-muted">Total: <%= barang.length %> barang</small>
                    </div>
                <% } else { %>
                    <div class="text-center py-5">
                        <i class="bi bi-inbox display-1 text-muted"></i>
                        <h5 class="mt-3">Belum ada data barang</h5>
                        <p class="text-muted">Silakan tambahkan barang baru</p>
                        <a href="/barang/create" class="btn btn-primary">
                            <i class="bi bi-plus-circle"></i> Tambah Barang
                        </a>
                    </div>
                <% } %>
            </div>
        </div>
    </div>
</div>